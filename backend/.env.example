# STEM Agent backend optional model configuration.
#
# Default behavior:
# - If these variables are not set, backend uses local feature-hash embeddings.
# - If LLM variables are not set, backend uses local answer synthesis.

# Retrieval pipeline.
STEM_VECTOR_BACKEND=faiss
STEM_VECTOR_ALLOW_LOCAL_FALLBACK=true
STEM_SPARSE_BACKEND=bm25
STEM_FUSION_STRATEGY=rrf
STEM_RRF_K=60
STEM_RAG_TOP_K=5
STEM_RAG_CANDIDATE_MULTIPLIER=6
STEM_RAG_MIN_CANDIDATE_K=18

# Embedding: OpenAI-compatible / DashScope-compatible API.
# Example base URL for DashScope compatible mode:
# STEM_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
STEM_EMBEDDING_PROVIDER=local
STEM_EMBEDDING_BASE_URL=
STEM_EMBEDDING_API_KEY=
STEM_EMBEDDING_MODEL=local-feature-hash-v1
STEM_EMBEDDING_DIM=384
STEM_EMBEDDING_BATCH_SIZE=10
STEM_EMBEDDING_ALLOW_LOCAL_FALLBACK=true

# Model reranker. When disabled or unavailable, backend uses local reranker.
STEM_RERANKER_PROVIDER=local
STEM_RERANKER_BASE_URL=
STEM_RERANKER_API_KEY=
STEM_RERANKER_MODEL=qwen-plus
STEM_RERANKER_TOP_N=20
STEM_RERANKER_ALLOW_LOCAL_FALLBACK=true

# LLM: OpenAI-compatible chat completions API.
# Example base URL for DashScope compatible mode:
# STEM_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
STEM_LLM_PROVIDER=openai_compatible
STEM_LLM_BASE_URL=
STEM_LLM_API_KEY=
STEM_LLM_MODEL=qwen-turbo
STEM_LLM_TEMPERATURE=0.3
STEM_LLM_MAX_TOKENS=700
STEM_LLM_ALLOW_LOCAL_FALLBACK=true
